# ==============================================================================
# TalentTrade Environment Variables Template
# Copy this file to '.env' and fill in your actual production values.
# DO NOT commit the '.env' file containing secrets to version control.
# ==============================================================================

# Active Spring Profile (e.g. dev, prod)
SPRING_PROFILES_ACTIVE=dev

# Backend Port Configuration
SPRING_PORT=8080

# Database Configuration (For Docker Compose Postgres Container)
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_PORT=5432
DB_NAME=talenttrade

# Database Connection Settings (For Spring Boot App)
# Local Docker development defaults to 'jdbc:postgresql://db:5432/talenttrade'
# For Neon PostgreSQL / production:
# - URL: jdbc:postgresql://<neon-hostname>:5432/talenttrade?sslmode=require
# - Username: <neon-user>
# - Password: <neon-password>
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/talenttrade
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
SPRING_JPA_DDL_AUTO=update

# JWT Authentication Config
# In production, must be a cryptographically secure, HEX-encoded 256-bit secret key.
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# CORS & WebSocket Allowed Origins (Comma-separated urls without trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend Production Environment Variables
# Map these in your Vercel deployment configurations
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=http://localhost:8080/ws

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
OAUTH2_REDIRECT_URI=http://localhost:5173/oauth2/redirect

# Administrative Bootstrapping
ADMIN_EMAIL=saicharanreddykolli@gmail.com

# Redis Configuration
# Local Docker development defaults to 'localhost' or 'redis' depending on host environment
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
